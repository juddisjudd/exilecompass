{
  "name": "exilecompass",
  "version": "1.2.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:no-detect": "EXILECOMPASS_NO_DETECT=1 tauri dev",
    "build": "vite build",
    "build:frontend": "vite build",
    "build:backend": "cargo build --manifest-path src-tauri/Cargo.toml --release",
    "build:release": "tauri build --no-bundle",
    "release": "tauri build",
    "release:tag": "node scripts/release.mjs",
    "preview": "vite preview",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "sync-guides": "node tools/sync-guides-fallback.mjs",
    "build:tree": "bun tools/build-poe1-tree.mjs",
    "build:poe1-regex-data": "bun tools/build-poe1-regex-data.mjs",
    "build:act-decoder-manifest": "bun tools/build-act-decoder-manifest.mjs",
    "addon:scaffold": "node tools/addon-scaffold/create-addon.mjs",
    "check": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/fira-mono": "^5.3.0",
    "@fontsource/inter": "^5.3.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-global-shortcut": "~2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.5",
    "yaml": "^2.9.0"
  }
}
