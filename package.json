{
  "name": "exilecompass",
  "version": "1.0.4",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:no-detect": "EXILECOMPASS_NO_DETECT=1 tauri dev",
    "build": "vite build",
    "build:frontend": "vite build",
    "build:backend": "cargo build --manifest-path src-tauri/Cargo.toml --release",
    "build:release": "tauri build --no-bundle",
    "release": "tauri build",
    "release:tag": "node scripts/release.mjs",
    "preview": "vite preview",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "sync-guides": "node tools/sync-guides-fallback.mjs",
    "build:tree": "bun tools/build-poe1-tree.mjs",
    "addon:scaffold": "node tools/addon-scaffold/create-addon.mjs",
    "check": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/fira-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.15.2",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
